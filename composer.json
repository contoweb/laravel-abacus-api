{
    "name": "contoweb/laravel-odata-client",
    "description": "Laravel wrapper for Abacus OData API to consume it in a Laravel way.",
    "version": "1.0.0",
    "type": "library",
    "keywords": [
        "laravel",
        "abacus",
        "rest",
        "odata",
        "api"
    ],
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Contoweb\\LaravelOdataClient\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Joel Rhenisch",
            "email": "joel.rhenisch@contoweb.ch"
        }
    ],
    "require": {
        "php": "^8.1|^8.2|^8.3",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/http": "^10.0|^11.0",
        "illuminate/console": "^10.0|^11.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
