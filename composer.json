{
    "name": "contoweb/laravel-abacus-api",
    "description": "Laravel wrapper for Abacus REST API to consume it in a Laravel way.",
    "type": "library",
    "keywords": [
        "laravel",
        "abacus",
        "rest",
        "odata",
        "api",
        "erp"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Joel Rhenisch",
            "email": "joel.rhenisch@contoweb.ch"
        }
    ],
    "require": {
        "php": "^8.2|^8.3|^8.4",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/console": "^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "orchestra/testbench": "^9.0|^10.0",
        "mockery/mockery": "^1.5"
    },
    "autoload": {
        "psr-4": {
            "Contoweb\\AbacusApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Contoweb\\AbacusApi\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Contoweb\\AbacusApi\\AbacusServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}